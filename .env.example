# Claude API
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=

# Internal API key — protects /extract and /articles endpoints
# Generate with: openssl rand -hex 32
API_KEY=

# Slack App
# Bot token from: api.slack.com → Your App → OAuth & Permissions → Bot User OAuth Token
SLACK_BOT_TOKEN=
# Signing secret from: api.slack.com → Your App → Basic Information → Signing Secret
SLACK_SIGNING_SECRET=

# Confluence
# Your Confluence base URL (e.g. https://yourname.atlassian.net/wiki)
CONFLUENCE_URL=
# Atlassian account email
CONFLUENCE_EMAIL=
# API token from: id.atlassian.com → Security → API tokens
CONFLUENCE_API_TOKEN=
# Space key for the demo KB space (e.g. KB, DEMO)
CONFLUENCE_SPACE_KEY=
